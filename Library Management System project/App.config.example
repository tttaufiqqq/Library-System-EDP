<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <add name="Library_Management_System_project.Properties.Settings.LibraryConnectionString" connectionString="Server=CHANGE_ME;Initial Catalog=Library;User Id=CHANGE_ME;Password=CHANGE_ME;Connect Timeout=30" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="MinioEndpoint" value="CHANGE_ME" />
    <add key="MinioAccessKey" value="CHANGE_ME" />
    <add key="MinioSecretKey" value="CHANGE_ME" />
    <add key="MinioBucket" value="library-book-covers" />
    <add key="MinioUseSSL" value="false" />
    <!-- ToyyibPay SANDBOX only (dev.toyyibpay.com) - never point this at the
         production host. billReturnUrl/billCallbackUrl are set to the base
         URL itself; see docs/fine-and-payment.md for why a desktop app
         cannot use either as its source of truth for payment success. -->
    <add key="ToyyibPayBaseUrl" value="https://dev.toyyibpay.com" />
    <add key="ToyyibPayCategoryCode" value="CHANGE_ME" />
    <add key="ToyyibPaySecretKey" value="CHANGE_ME" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <entityFramework>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
